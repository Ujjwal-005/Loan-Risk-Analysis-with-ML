│   ├── loan_xgb_model_pipeline.pkl
│   └── shap_explainer.pkl
├── pages/
│   ├── __init__.py
│   ├── cluster.py
│   ├── eligibility.py
│   └── learn_more.py
└── utils/
    ├── __init__.py
    ├── constants.py
    ├── validators.py
    ├── models.py
    ├── visualizations.py
    ├── llm_handler.py
    ├── prompts.py
